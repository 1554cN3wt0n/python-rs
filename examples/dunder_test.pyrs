class Vector:
    def __init__(self, x, y):
        self.x = x
        self.y = y
    
    def __add__(self, other):
        return Vector(self.x + other.x, self.y + other.y)
    
    def __str__(self):
        return "Vector(" + str(self.x) + ", " + str(self.y) + ")"
    
    def __len__(self):
        return 2

class MyList:
    def __init__(self, data):
        self.data = data
    
    def __getitem__(self, index):
        return self.data[index]
    
    def __contains__(self, item):
        for x in self.data:
            if x == item:
                return True
        return False

# Test __add__ and __str__
v1 = Vector(1, 2)
v2 = Vector(3, 4)
v3 = v1 + v2
print("v1 + v2 =", v3)

# Test __len__
print("len(v1) =", len(v1))

# Test __getitem__
ml = MyList([10, 20, 30])
print("ml[1] =", ml[1])

# Test __contains__ (in operator)
print("20 in ml =", 20 in ml)
print("40 in ml =", 40 in ml)
